generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id          String      @id @default(cuid())
  slug        String      @unique
  status      EventStatus @default(DRAFT)
  startDate   DateTime
  endDate     DateTime
  location    String
  imageUrl      String?
  heroTextColor String      @default("auto")
  createdAt     DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  translations  EventTranslation[]
  registrations Registration[]
  media         EventMedia[]
  documents     EventDocument[]

  @@map("events")
}

model EventMedia {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url        String
  altText    String?
  caption    String?
  isCover    Boolean  @default(false)
  isFeatured Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([eventId])
  @@map("event_media")
}

model EventTranslation {
  id          String  @id @default(cuid())
  eventId     String
  locale      Locale
  title       String
  description String  @db.Text
  agenda      String? @db.Text
  location    String? // localized city/country name; falls back to event.location

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, locale])
  @@map("event_translations")
}

model Registration {
  id           String             @id @default(cuid())
  eventId      String
  firstName    String
  lastName     String
  email        String
  country      String
  organization String?
  position     String?
  dietaryNeeds String?
  status       RegistrationStatus @default(PENDING)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("registrations")
}

model EventDocument {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  locale    Locale
  category  String
  title     String
  fileUrl   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([eventId, locale])
  @@map("event_documents")
}

model Document {
  id       String           @id @default(cuid())
  eventId  String?
  category DocumentCategory
  fileUrl  String
  fileSize Int
  mimeType String
  isPublic Boolean          @default(false)
  createdAt DateTime        @default(now())

  translations DocumentTranslation[]

  @@map("documents")
}

model DocumentTranslation {
  id         String @id @default(cuid())
  documentId String
  locale     Locale
  title      String

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, locale])
  @@map("document_translations")
}

enum Locale {
  en
  ru
  tr
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  REJECTED
  WAITLISTED
}

enum DocumentCategory {
  AGENDA
  MINUTES
  RESOLUTION
  REPORT
  PRESS_RELEASE
  OTHER
}

model AuthUser {
  id                  String     @id @default(cuid())
  username            String     @unique
  email               String     @unique
  passwordHash        String
  firstName           String
  lastName            String
  country             String
  role                String
  status              UserStatus @default(PENDING)
  photoUrl            String?
  uploadedPhotoUrl    String?
  adminNotes          String?
  createdAt           DateTime   @default(now())
  approvedAt          DateTime?
  approvedBy          String?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  resetToken          String?    @unique
  resetTokenExpiry    DateTime?

  @@map("auth_users")
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}
