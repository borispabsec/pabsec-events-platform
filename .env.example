# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pabsec?schema=public"

# ─── Next.js ─────────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""          # openssl rand -base64 32

# ─── Email (for registration confirmations) ───────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@pabsec.org"

# ─── Storage (document uploads) ───────────────────────────────────────────────
# S3-compatible: AWS S3, MinIO, Cloudflare R2, etc.
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET="pabsec-documents"
STORAGE_REGION="eu-central-1"
